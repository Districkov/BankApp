    },
    {
      "source": "/api/accounts/:path*",
      "destination": "https://bank.korzik.space/api/accounts/v1/:path*"
    },
    {
      "source": "/api/transfers/:path*",
      "destination": "https://bank.korzik.space/api/transfers/v1/:path*"
    }
  ]
}
