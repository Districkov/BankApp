{
  "expo": {
    "name": "BankApp",
    "slug": "bankapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "bankapp",
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.korzik.bankapp",
      "associatedDomains": [
        "applinks:auth.korzik.space"
      ]
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#6A2EE8"
      },
      "package": "com.korzik.bankapp",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "bankapp",
              "host": "auth",
              "pathPrefix": "/code/telegram"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
