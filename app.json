{
  "expo": {
    "name": "BankApp",
    "slug": "bankapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "bankapp",
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.korzik.bankapp",
      "associatedDomains": [
        "applinks:auth.korzik.space"
      ]
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#6A2EE8"
      },
      "package": "com.korzik.bankapp",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "bankapp",
              "host": "auth",
              "pathPrefix": "/code/telegram"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "output": "single",
      "name": "BankApp",
      "shortName": "BankApp",
      "description": "Банковское приложение для управления финансами",
      "lang": "ru",
      "themeColor": "#6A2EE8",
      "backgroundColor": "#ffffff",
      "display": "standalone",
      "orientation": "portrait",
      "startUrl": "/",
      "scope": "/"
    }
  }
}
